# Copy to .env and adjust (optional — defaults work for local SQLite under backend/data/).

# SQLite (default): sqlite:///... path relative to backend/ or absolute
# DATABASE_URL=sqlite:///data/portfolio.db

# Comma-separated origins for CORS (dev: Vite on 5173)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Pause between Yahoo Finance ticker requests (seconds) — raise if you hit HTTP 429
# YAHOO_REQUEST_DELAY_SECONDS=0.55

# How many full portfolio JSON backups to keep after each change
# PORTFOLIO_BACKUP_VERSIONS=3

# Retention for incremental daily price history backups (days)
# PRICE_BACKUP_KEEP_DAYS=120

# Set to 1 to disable APScheduler jobs (tests / CI)
# SKIP_SCHEDULER=1
